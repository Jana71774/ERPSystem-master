@model ERPSystem.Models.Customer
<link rel="stylesheet" href="~/css/site.css" />

<div class="main-content">

    <!-- Top Bar -->
    <div class="topbar" style="display:flex;justify-content:space-between;align-items:center">
        <h3>➕ Add Customer</h3>

        <!-- 🔙 BACK (PREVIOUS PAGE) -->
        <button type="button"
                onclick="goBack();"
                style="background:none;border:none;
                       color:#2a5298;font-weight:600;
                       cursor:pointer;">
            ← Back
        </button>
    </div>

    <!-- Card -->
    <div class="card" style="max-width:900px;margin:auto;padding:30px">

        <form asp-action="Create" method="post">

            <!-- Header -->
            <div style="background:#f1f5f9;padding:15px;border-radius:8px;margin-bottom:25px">
                <h4 style="margin:0;color:#2a5298">Customer Information</h4>
                <small style="color:#666">Enter new customer details</small>
            </div>

            <!-- Form Grid -->
            <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:22px">

                <div>
                    <label class="form-label">Customer ID</label>
                    <input name="CustomerID" class="form-input"
                           placeholder="Enter Customer ID" required />
                </div>

                <div>
                    <label class="form-label">Contact Person</label>
                    <input name="ContactPerson" class="form-input"
                           placeholder="Contact Person Name" />
                </div>

                <div>
                    <label class="form-label">Phone Number</label>
                    <input name="PhoneNo" class="form-input"
                           placeholder="Phone Number" />
                </div>

                <div>
                    <label class="form-label">Email Address</label>
                    <input name="Email" class="form-input"
                           placeholder="Email Address" />
                </div>

                <div>
                    <label class="form-label">Region</label>
                    <input name="Region" class="form-input"
                           placeholder="Region" />
                </div>

                <div>
                    <label class="form-label">Address</label>
                    <input name="Address" class="form-input"
                           placeholder="Customer Address" />
                </div>

            </div>

            <!-- Buttons -->
            <div style="margin-top:30px;display:flex;justify-content:flex-end;gap:15px">

                <!-- 🔙 CANCEL = PREVIOUS PAGE -->
                <button type="button"
                        onclick="goBack();"
                        style="background:#e5e7eb;color:#111;
                               padding:10px 18px;border-radius:6px;
                               border:none;font-weight:600;">
                    Cancel
                </button>

                <button type="submit"
                        style="background:#2a5298;color:white;
                               padding:12px 22px;border-radius:8px;
                               border:none;font-weight:600;cursor:pointer;">
                    💾 Save Customer
                </button>

            </div>

        </form>

    </div>
</div>

<script>
    function goBack() {
        if (document.referrer && document.referrer !== window.location.href) {
            window.history.back();
        } else {
            // 🔁 safe fallback
            window.location.href = '/Customer/Index';
        }
    }
</script>

<style>
    .form-label {
        font-size: 13px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
        display: block;
    }

    .form-input {
        width: 100%;
        padding: 10px 12px;
        border-radius: 6px;
        border: 1px solid #d1d5db;
        outline: none;
        font-size: 14px;
    }

        .form-input:focus {
            border-color: #2a5298;
            box-shadow: 0 0 0 2px rgba(42,82,152,0.15);
        }
</style>

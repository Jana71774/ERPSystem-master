@model List<ERPSystem.Models.Customer>
<link rel="stylesheet" href="~/css/site.css" />

<div class="main-content">

    <div class="topbar" style="display:flex;justify-content:space-between;align-items:center">
        <h3>Customers</h3>

        <div style="display:flex;gap:12px;align-items:center">

            <!-- 🔙 BACK (PREVIOUS PAGE) -->
            <button type="button"
                    onclick="goBack();"
                    style="background:#e5e7eb;color:#111;
                           padding:8px 14px;border-radius:6px;
                           border:none;font-weight:600;">
                ← Back
            </button>

            <!-- ➕ ADD CUSTOMER -->
            <a asp-controller="Customer" asp-action="Create"
               style="background:#2a5298;color:white;
                      padding:10px 15px;border-radius:6px;
                      text-decoration:none;">
                + Add Customer
            </a>

        </div>
    </div>

    <div class="card">

    <ejs-grid id="CustomerGrid"
              dataSource="@Model">

        <e-grid-columns>

            <e-grid-column field="CustomerID"
                           headerText="ID"
                           width="100">
            </e-grid-column>

            <e-grid-column field="ContactPerson"
                           headerText="Contact Person"
                           width="180">
            </e-grid-column>

            <e-grid-column field="Region"
                           headerText="Region"
                           width="150">
            </e-grid-column>

            <e-grid-column field="Email"
                           headerText="Email"
                           width="200">
            </e-grid-column>

            <e-grid-column field="PhoneNo"
                           headerText="Phone"
                           width="150">
            </e-grid-column>

            <e-grid-column headerText="Action"
                           width="120"
                           template="#actionTemplate">
            </e-grid-column>

        </e-grid-columns>

    </ejs-grid>

</div>

<script id="actionTemplate" type="text/x-template">
    <a href="/Customer/Edit/${CustomerID}">
        Edit
    </a>
</script>

    </div>
</div>

<script>
    function goBack() {
        if (document.referrer && document.referrer !== window.location.href) {
            window.history.back();
        } else {
            // 🔁 safe fallback
            window.location.href = '/';
        }
    }
</script>

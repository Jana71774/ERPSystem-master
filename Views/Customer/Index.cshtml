<script src="https://cdn.syncfusion.com/ej2/25.1.35/dist/ej2.min.js"></script>

<script>
    var customerData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

    var grid = new ej.grids.Grid({
        dataSource: customerData,
        height: 400,

        allowPaging: true,
        allowSorting: true,
        allowFiltering: true,
        allowSearching: true,

        toolbar: ['Search'],

        columns: [
            { field: 'CustomerID', headerText: 'ID', width: 100, textAlign: 'Center' },
            { field: 'ContactPerson', headerText: 'Contact Person', width: 180 },
            { field: 'Region', headerText: 'Region', width: 150 },
            { field: 'Email', headerText: 'Email', width: 220 },
            { field: 'PhoneNo', headerText: 'Phone', width: 150 },

            {
                headerText: 'Action',
                width: 120,
                template: function (data) {
                    return `<a href="/Customer/Edit/${data.CustomerID}" 
                               style="color:#2563eb;font-weight:600;">
                               Edit
                            </a>`;
                }
            }
        ]
    });

    grid.appendTo('#Grid');


    function goBack() {
        if (document.referrer && document.referrer !== window.location.href) {
            window.history.back();
        } else {
            window.location.href = '/';
        }
    }
</script>
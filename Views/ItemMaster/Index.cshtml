@model List<ERPSystem.Models.ItemMaster>
<link rel="stylesheet" href="~/css/site.css" />
<link href="https://cdn.syncfusion.com/ej2/25.1.35/material.css" rel="stylesheet">

<div class="main-content">

    <div class="topbar"
         style="display:flex;justify-content:space-between;align-items:center">

        <h3>Item Master</h3>

        <div style="display:flex;gap:12px;align-items:center">

            <!-- 🔙 BACK -->
            <button type="button"
                    onclick="goBack();"
                    style="background:#e5e7eb;color:#111;
                           padding:8px 14px;border-radius:6px;
                           border:none;font-weight:600;">
                ← Back
            </button>

            <a asp-action="Create"
               style="background:#2a5298;color:white;
                      padding:8px 14px;border-radius:6px;
                      text-decoration:none;font-weight:600;">
                + Add Item
            </a>
        </div>
    </div>

    <div class="card" style="margin-top:20px;padding:20px">

        <!-- GRID -->
        <div id="Grid"></div>

    </div>
</div>

<script src="https://cdn.syncfusion.com/ej2/25.1.35/dist/ej2.min.js"></script>

<script>
    var itemMasterData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

    var grid = new ej.grids.Grid({
        dataSource: itemMasterData,
        height: 450,

        allowPaging: true,
        allowSorting: true,
        allowFiltering: true,
        allowSearching: true,

        toolbar: ['Search'],

        columns: [
            { field: 'ItemCode', headerText: 'Item Code', width: 160 },
            { field: 'ItemName', headerText: 'Item Name', width: 220 },
            { field: 'ItemType', headerText: 'Type', width: 160 },

            {
                headerText: 'Edit',
                width: 120,
                template: function (data) {
                    return `<a href="/ItemMaster/Edit/${data.ItemCode}"
                               style="color:#2563eb;font-weight:600;text-decoration:none">
                               Edit
                            </a>`;
                }
            }
        ]
    });

    grid.appendTo('#Grid');
</script>

<script>
    function goBack() {
        if (document.referrer && document.referrer !== window.location.href) {
            window.history.back();
        } else {
            window.location.href = '/ItemMaster/Index';
        }
    }
</script>
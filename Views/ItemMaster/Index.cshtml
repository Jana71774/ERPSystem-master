@model List<ERPSystem.Models.ItemMaster>
<link rel="stylesheet" href="~/css/site.css" />

<div class="main-content">

    <div class="topbar"
         style="display:flex;justify-content:space-between;align-items:center">

        <h3>Item Master</h3>

        <div style="display:flex;gap:12px;align-items:center">

            <!-- 🔙 BACK -->
            <button type="button"
                    onclick="goBack();"
                    style="background:#e5e7eb;color:#111;
                           padding:8px 14px;border-radius:6px;
                           border:none;font-weight:600;">
                ← Back
            </button>

            <a asp-action="Create"
               style="background:#2a5298;color:white;
                      padding:8px 14px;border-radius:6px;
                      text-decoration:none;font-weight:600;">
                + Add Item
            </a>
        </div>
    </div>

    <div class="card" style="margin-top:20px;padding:20px">

        <table width="100%" cellpadding="12" cellspacing="0"
               style="border-collapse:collapse">

            <thead style="background:#f1f5f9">
                <tr>
                    <th>Item Code</th>
                    <th>Item Name</th>
                    <th>Type</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var i in Model)
                {
                    <tr style="border-bottom:1px solid #e5e7eb">
                        <td>@i.ItemCode</td>
                        <td style="font-weight:600">@i.ItemName</td>
                        <td>@i.ItemType</td>
                        <td>
                            <a asp-action="Edit"
                               asp-route-id="@i.ItemCode"
                               style="color:#2563eb;font-weight:600;text-decoration:none;">
                                Edit
                            </a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>
</div>

<script>
    function goBack() {
        if (document.referrer && document.referrer !== window.location.href) {
            window.history.back();
        } else {
            window.location.href = '/ItemMaster/Index';
        }
    }
</script>

@model ERPSystem.Models.ItemMaster
<link rel="stylesheet" href="~/css/site.css" />

<div class="main-content">

    <!-- TOP BAR -->
    <div class="topbar" style="display:flex;justify-content:space-between;align-items:center">
        <h3>✏ Edit Item Master</h3>

        <button type="button"
                onclick="goBack();"
                style="background:none;border:none;color:#2a5298;
                       font-weight:600;cursor:pointer;">
            ← Back
        </button>
    </div>

    <div class="card" style="max-width:900px;margin:auto;padding:30px">

        <form asp-action="Edit" method="post">

            <div style="background:#f1f5f9;padding:15px;border-radius:8px;margin-bottom:25px;
                        display:flex;justify-content:space-between;align-items:center">
                <div>
                    <h4 style="margin:0;color:#2a5298">Item Master Details</h4>
                    <small style="color:#666">Update item information</small>
                </div>

                <div>
                    <label style="font-size:12px;color:#666">Item Code</label>
                    <input name="ItemCode" value="@Model.ItemCode" readonly
                           style="background:#e5e7eb;font-weight:bold;text-align:center;width:160px" />
                </div>
            </div>

            <!-- FORM GRID -->
            <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:22px">

                <div>
                    <label class="form-label">Item Name</label>
                    <input name="ItemName" value="@Model.ItemName" class="form-input" />
                </div>

                <div>
                    <label class="form-label">Item Type</label>
                    <select name="ItemType" id="itemType"
                            onchange="toggleSpecs()"
                            class="form-input">
                        @if (Model.ItemType == "Static")
                        {
                            <option value="Static" selected>Static</option>
                            <option value="Variable">Variable</option>
                        }
                        else
                        {
                            <option value="Static">Static</option>
                            <option value="Variable" selected>Variable</option>
                        }
                    </select>
                </div>

                <div style="grid-column:1/3">
                    <label class="form-label">Description</label>
                    <textarea name="ItemDesc" class="form-input">@Model.ItemDesc</textarea>
                </div>

                <!-- VARIABLE GRID (SCREENSHOT STYLE) -->
                <div id="variableSection"
                     style="display:none;grid-column:1/3;margin-top:25px">

                    <h4 style="color:#2a5298;margin-bottom:10px">
                        Specifications (Variable Item)
                    </h4>

                    <table width="100%" cellpadding="10"
                           style="border-collapse:collapse;border:1px solid #e5e7eb">

                        <thead>
                            <tr style="background:#f1f5f9;border-bottom:1px solid #e5e7eb">
                                <th style="text-align:left;font-size:12px;padding:10px">Stock ID</th>
                                <th style="text-align:left;font-size:12px;padding:10px">Spec 1</th>
                                <th style="text-align:left;font-size:12px;padding:10px">Spec 2</th>
                                <th style="text-align:left;font-size:12px;padding:10px">Spec 3</th>
                                <th style="text-align:left;font-size:12px;padding:10px">Spec 4</th>
                            </tr>
                        </thead>

                        <tbody>
                            <tr>
                                <td style="padding:8px">
                                    <input name="StockID" class="form-input" placeholder="STK001" />
                                </td>
                                <td style="padding:8px">
                                    <input name="Spec1" class="form-input" placeholder="e.g. Size" />
                                </td>
                                <td style="padding:8px">
                                    <input name="Spec2" class="form-input" placeholder="e.g. Color" />
                                </td>
                                <td style="padding:8px">
                                    <input name="Spec3" class="form-input" placeholder="e.g. Grade" />
                                </td>
                                <td style="padding:8px">
                                    <input name="Spec4" class="form-input" placeholder="e.g. Finish" />
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

            </div>

            <!-- BUTTONS -->
            <div style="margin-top:30px;display:flex;justify-content:flex-end;gap:15px">

                <button type="button"
                        onclick="goBack();"
                        style="background:#e5e7eb;color:#111;padding:10px 18px;
                               border-radius:6px;border:none;font-weight:600;">
                    Cancel
                </button>

                <button type="submit"
                        style="background:#2a5298;color:white;padding:12px 22px;
                               border-radius:8px;border:none;font-weight:600;">
                    💾 Update Item
                </button>

            </div>

        </form>
    </div>
</div>

<script>
    function toggleSpecs() {
        var type = document.getElementById("itemType").value;
        document.getElementById("variableSection").style.display =
            type === "Variable" ? "block" : "none";
    }

    function goBack() {
        if (document.referrer && document.referrer !== window.location.href) {
            window.history.back();
        } else {
            window.location.href = '/ItemMaster/Index';
        }
    }

    toggleSpecs(); // run on load
</script>

<style>
    .form-label {
        font-size: 13px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
        display: block;
    }

    .form-input {
        width: 100%;
        padding: 10px 12px;
        border-radius: 6px;
        border: 1px solid #d1d5db;
        outline: none;
        font-size: 14px;
    }

        .form-input:focus {
            border-color: #2a5298;
            box-shadow: 0 0 0 2px rgba(42,82,152,0.15);
        }
</style>

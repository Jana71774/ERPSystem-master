@model ERPSystem.Models.GRN
<link rel="stylesheet" href="~/css/site.css" />

<div class="main-content">

    <!-- Top Bar -->
    <div class="topbar" style="display:flex;justify-content:space-between;align-items:center">
        <h3>➕ Create GRN</h3>

        <!-- 🔙 BACK -->
        <button type="button"
                onclick="goBack();"
                style="background:none;border:none;
                       color:#2a5298;font-weight:600;
                       cursor:pointer;">
            ← Back
        </button>
    </div>

    <!-- Card -->
    <div class="card" style="max-width:900px;margin:auto;padding:30px">

        <form asp-action="Create" method="post">

            <!-- Header Box -->
            <div style="background:#f1f5f9;padding:15px;border-radius:8px;margin-bottom:25px">
                <h4 style="margin:0;color:#2a5298">GRN Information</h4>
                <small style="color:#666">Enter GRN details</small>
            </div>

            <!-- Form Grid -->
            <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:22px">

                <!-- GRN Date -->
                <div>
                    <label class="form-label">GRN Date</label>
                    <input type="date"
                           name="GRNDate"
                           class="form-input"
                           required />
                </div>

                <!-- Item Code -->
                <div>
                    <label class="form-label">Item Code</label>
                    <input name="ItemCode"
                           class="form-input"
                           placeholder="Enter Item Code"
                           required />
                </div>

                <!-- Quantity -->
                <div>
                    <label class="form-label">Quantity</label>
                    <input type="number"
                           step="0.01"
                           min="0"
                           name="Qty"
                           class="form-input"
                           required />
                </div>

                <!-- Batch Code -->
                <div>
                    <label class="form-label">Batch Code</label>
                    <input name="BatchCode"
                           class="form-input"
                           placeholder="Optional batch reference" />
                </div>

                <!-- Login ID -->
                <div>
                    <label class="form-label">Login ID</label>
                    <input name="LoginID"
                           class="form-input"
                           placeholder="User login ID" />
                </div>

                <!-- Vendor Name -->
                <div>
                    <label class="form-label">Vendor Name</label>
                    <input name="VendorName"
                           class="form-input"
                           placeholder="Supplier / Vendor" />
                </div>

                <!-- Value Quantity -->
                <div>
                    <label class="form-label">Value Quantity / Amount</label>
                    <input type="number"
                           step="0.01"
                           min="0"
                           name="ValueQty"
                           class="form-input"
                           placeholder="Enter value amount" />
                </div>

            </div>

            <!-- Buttons -->
            <div style="margin-top:30px;display:flex;justify-content:flex-end;gap:15px">

                <!-- Cancel -->
                <button type="button"
                        onclick="goBack();"
                        style="background:#e5e7eb;color:#111;
                               padding:10px 18px;border-radius:6px;
                               border:none;font-weight:600;">
                    Cancel
                </button>

                <!-- Save -->
                <button type="submit"
                        style="background:#2a5298;color:white;
                               padding:12px 22px;border-radius:8px;
                               border:none;font-weight:600;cursor:pointer;">
                    💾 Save GRN
                </button>

            </div>

        </form>
    </div>
</div>

<script>
    function goBack() {
        if (document.referrer && document.referrer !== window.location.href) {
            window.history.back();
        } else {
            window.location.href = '/GRN/Index';
        }
    }
</script>

<style>
    .form-label {
        font-size: 13px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
        display: block;
    }

    .form-input {
        width: 100%;
        padding: 10px 12px;
        border-radius: 6px;
        border: 1px solid #d1d5db;
        outline: none;
        font-size: 14px;
    }

    .form-input:focus {
        border-color: #2a5298;
        box-shadow: 0 0 0 2px rgba(42,82,152,0.15);
    }
</style>
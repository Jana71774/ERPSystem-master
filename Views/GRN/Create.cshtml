@model ERPSystem.Models.GRN
<link rel="stylesheet" href="~/css/site.css" />

<div class="main-content">

    <div class="topbar">
        <h3>➕ Create GRN</h3>
        <a asp-action="Index">← Back</a>
    </div>

    <div class="card" style="max-width:900px;margin:auto;padding:30px">

        <form asp-action="Create" method="post">

            <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:22px">

                <div>
                    <label>GRN Date</label>
                    <input type="date" name="GRNDate" class="form-input" required />
                </div>

                <div>
                    <label>Item Code</label>
                    <input name="ItemCode" class="form-input" required />
                </div>

                <div>
                    <label>Qty</label>
                    <input type="number" step="0.01" name="Qty" class="form-input" required />
                </div>

                <div>
                    <label>Batch Code</label>
                    <input name="BatchCode" class="form-input" />
                </div>

                <div>
                    <label>Login ID</label>
                    <input name="LoginID" class="form-input" />
                </div>

                <div>
                    <label>Vendor Name</label>
                    <input name="VendorName" class="form-input" />
                </div>

                <div>
                    <label>Value Qty</label>
                    <input type="number" step="0.01" name="ValueQty" class="form-input" />
                </div>

            </div>

            <div style="margin-top:25px;text-align:right">
                <button type="submit" class="btn btn-primary">Save GRN</button>
            </div>

        </form>
    </div>
</div>

@model List<ERPSystem.Models.GRN>
<link rel="stylesheet" href="~/css/site.css" />

<!-- Syncfusion CSS -->
<link href="https://cdn.syncfusion.com/ej2/25.1.35/material.css" rel="stylesheet" />

<div class="main-content">

    <div class="topbar" style="display:flex;justify-content:space-between;align-items:center">
        <h3>GRN Register</h3>

        <a asp-action="Create"
           style="background:#2a5298;color:white;padding:10px 15px;border-radius:6px;text-decoration:none;">
            + Add GRN
        </a>
    </div>

    <div class="card" style="margin-top:20px;padding:20px">

        <div id="Grid"></div>

    </div>
</div>

<!-- Syncfusion JS -->
<script src="https://cdn.syncfusion.com/ej2/25.1.35/dist/ej2.min.js"></script>

<script>
    var grnData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

    var grid = new ej.grids.Grid({
        dataSource: grnData,
        height: 450,

        allowPaging: true,
        allowSorting: true,
        allowFiltering: true,
        allowSearching: true,

        toolbar: ['Search'],

        columns: [
            { field: 'GRNID', headerText: 'GRN ID', width: 110, textAlign: 'Center' },
            { field: 'GRNDate', headerText: 'Date', width: 140, type: 'date', format: 'yyyy-MM-dd' },
            { field: 'ItemCode', headerText: 'Item Code', width: 140 },
            { field: 'Qty', headerText: 'Qty', width: 100, textAlign: 'Right' },
            { field: 'BatchCode', headerText: 'Batch', width: 130 },
            { field: 'LoginID', headerText: 'Login', width: 130 },
            { field: 'VendorName', headerText: 'Vendor', width: 200 },
            { field: 'ValueQty', headerText: 'ValueQty', width: 120, textAlign: 'Right' },

            {
                headerText: 'Action',
                width: 120,
                template: function (data) {
                    return `<a href="/GRN/Edit/${data.GRNID}" 
                               style="color:#2563eb;font-weight:600;text-decoration:none;">
                               Edit
                            </a>`;
                }
            }
        ]
    });

    grid.appendTo('#Grid');
</script>
@model ERPSystem.Models.Spec

@{
    ViewData["Title"] = "Add Specification";
    Layout = "_Layout";
}

<style>
    .erp-form {
        max-width: 600px;
        margin: auto;
        border: 2px solid #2da2ff;
        border-radius: 6px;
        background: #f9fbfd;
        padding: 20px;
    }
</style>

<form asp-action="Create" method="post">

    <div class="mb-3">
        <label class="form-label">Item Code</label>
        <input asp-for="ItemCode"
               class="form-control"
               required />
    </div>

    <div class="mb-3">
        <label class="form-label">Spec ID</label>
        <input asp-for="SpecId"
               class="form-control"
               required />
    </div>

    <div class="mb-3">
        <label class="form-label">Spec Data</label>
        <input asp-for="SpecData"
               class="form-control"
               required />
    </div>

    <div class="mb-3">
        <label class="form-label">Spec Value</label>
        <input asp-for="SpecValue"
               class="form-control"
               required />
    </div>

    <button class="btn btn-primary">
        Save
    </button>

</form>
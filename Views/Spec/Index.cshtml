@model List<ERPSystem.Models.Spec>
@{
    ViewData["Title"] = "Item Specifications";
    Layout = "_Layout";
}

<style>
    .erp-card {
        border: 2px solid #2da2ff;
        border-radius: 6px;
        background: #f9fbfd;
        padding: 20px;
    }

    .erp-title {
        font-weight: 600;
        font-size: 16px;
    }
</style>

<div class="container-fluid mt-3">
    <div class="erp-card">

        <!-- HEADER -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="erp-title">
                Specifications – @ViewBag.ItemCode
            </div>

            <div class="d-flex gap-2">
                <!-- 🔙 BACK -->
                <button type="button"
                        class="btn btn-sm btn-secondary"
                        onclick="history.back();">
                    ← Back
                </button>

                <!-- ➕ ADD SPEC -->
                <a asp-action="Create"
                   asp-route-itemCode="@ViewBag.ItemCode"
                   asp-route-itemName="@ViewBag.ItemName"
                   class="btn btn-sm btn-primary">
                    + Add Spec
                </a>
            </div>
        </div>

        <!-- TABLE -->
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Spec ID</th>
                    <th>Spec Data</th>
                    <th>Spec Value</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td>@s.SpecId</td>
                        <td>@s.SpecData</td>
                        <td>@s.SpecValue</td>
                        <td class="text-end">
                            <a asp-action="Edit"
                               asp-route-itemCode="@s.ItemCode"
                               asp-route-specId="@s.SpecId"
                               class="btn btn-sm btn-outline-primary">
                                Edit
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>

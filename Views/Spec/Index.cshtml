@model List<ERPSystem.Models.Spec>
@{
    ViewData["Title"] = "Item Specifications";
    Layout = "_Layout";
}

<link href="https://cdn.syncfusion.com/ej2/25.1.35/material.css" rel="stylesheet">

<style>
    .erp-card {
        border: 2px solid #2da2ff;
        border-radius: 6px;
        background: #f9fbfd;
        padding: 20px;
    }

    .erp-title {
        font-weight: 600;
        font-size: 16px;
    }
</style>

<div class="container-fluid mt-3">
    <div class="erp-card">

        <!-- HEADER -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="erp-title">
                Specifications – @ViewBag.ItemCode
            </div>

            <div class="d-flex gap-2">

                <button type="button"
                        class="btn btn-sm btn-secondary"
                        onclick="history.back();">
                    ← Back
                </button>

                <a asp-action="Create"
                   asp-route-itemCode="@ViewBag.ItemCode"
                   asp-route-itemName="@ViewBag.ItemName"
                   class="btn btn-sm btn-primary">
                    + Add Spec
                </a>

            </div>
        </div>

        <!-- GRID -->
        <div id="Grid"></div>

    </div>
</div>

<script src="https://cdn.syncfusion.com/ej2/25.1.35/dist/ej2.min.js"></script>

<script>
    var specData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));
    var itemName = "@ViewBag.ItemName";

    var grid = new ej.grids.Grid({
        dataSource: specData,
        height: 450,

        allowPaging: true,
        allowSorting: true,
        allowFiltering: true,
        allowSearching: true,

        toolbar: ['Search'],

        columns: [
            {
                headerText: 'Item Name',
                width: 200,
                template: function () {
                    return `<span style="font-weight:600">${itemName}</span>`;
                }
            },
            { field: 'SpecId', headerText: 'Spec ID', width: 150 },
            { field: 'SpecData', headerText: 'Spec Data', width: 200 },
            { field: 'SpecValue', headerText: 'Spec Value', width: 200 },

            {
                headerText: 'Edit',
                width: 120,
                template: function (data) {
                    return `<a href="/Spec/Edit?itemCode=${data.ItemCode}&specId=${data.SpecId}"
                               style="color:#2563eb;font-weight:600;text-decoration:none">
                               Edit
                            </a>`;
                }
            }
        ]
    });

    grid.appendTo('#Grid');
</script>
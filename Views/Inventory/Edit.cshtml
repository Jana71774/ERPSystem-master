@model ERPSystem.Models.Inventory

<link rel="stylesheet" href="~/css/site.css" />

<div class="main-content">

    <!-- TOP BAR -->
    <div class="topbar" style="display:flex;justify-content:space-between;align-items:center">
        <h3>✏ Edit Inventory</h3>

        <!-- BACK -->
        <button type="button"
                onclick="goBack();"
                style="background:none;border:none;color:#2a5298;
                       font-weight:600;cursor:pointer;">
            ← Back
        </button>
    </div>

    <!-- CARD -->
    <div class="card" style="max-width:900px;margin:auto;padding:30px">

        <form asp-action="Edit" method="post">

            <!-- Hidden Key -->
            <input type="hidden" asp-for="ItemCode" />

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <!-- HEADER -->
            <div style="background:#f1f5f9;padding:15px;border-radius:8px;margin-bottom:25px;
                        display:flex;justify-content:space-between;align-items:center">
                <div>
                    <h4 style="margin:0;color:#2a5298">Inventory Details</h4>
                    <small style="color:#666">Update stock record</small>
                </div>

                <div>
                    <label style="font-size:12px;color:#666">Item Code</label>
                    <input asp-for="ItemCode"
                           readonly
                           style="background:#e5e7eb;font-weight:bold;text-align:center;width:160px" />
                </div>
            </div>

            <!-- FORM GRID -->
            <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:22px">

                <!-- Available Qty -->
                <div>
                    <label asp-for="AvlQty" class="form-label"></label>
                    <input asp-for="AvlQty"
                           type="number"
                           step="0.01"
                           min="0"
                           class="form-input" />
                    <span asp-validation-for="AvlQty" class="text-danger"></span>
                </div>

                <!-- Minimum Qty -->
                <div>
                    <label asp-for="MinQty" class="form-label"></label>
                    <input asp-for="MinQty"
                           type="number"
                           step="0.01"
                           min="0"
                           class="form-input" />
                    <span asp-validation-for="MinQty" class="text-danger"></span>
                </div>

                <!-- Order Qty -->
                <div>
                    <label asp-for="OrderQty" class="form-label"></label>
                    <input asp-for="OrderQty"
                           type="number"
                           step="0.01"
                           min="0"
                           class="form-input" />
                    <span asp-validation-for="OrderQty" class="text-danger"></span>
                </div>

                <!-- Login ID -->
                <div>
                    <label asp-for="LoginID" class="form-label"></label>
                    <input asp-for="LoginID" class="form-input" readonly />
                    <span asp-validation-for="LoginID" class="text-danger"></span>
                </div>

                <!-- Login Name -->
                <div>
                    <label asp-for="LoginName" class="form-label"></label>
                    <input asp-for="LoginName" class="form-input" readonly />
                    <span asp-validation-for="LoginName" class="text-danger"></span>
                </div>

                <!-- Description -->
                <div style="grid-column:1/3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description"
                              rows="3"
                              class="form-input"
                              placeholder="Optional notes"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

            </div>

            <!-- BUTTONS -->
            <div style="margin-top:30px;display:flex;justify-content:flex-end;gap:15px">

                <button type="button"
                        onclick="goBack();"
                        style="background:#e5e7eb;color:#111;padding:10px 18px;
                               border-radius:6px;border:none;font-weight:600;cursor:pointer;">
                    Cancel
                </button>

                <button type="submit"
                        style="background:#2a5298;color:white;padding:12px 22px;
                               border-radius:8px;border:none;font-weight:600;cursor:pointer;">
                    💾 Update Inventory
                </button>

            </div>

        </form>

        @await Html.PartialAsync("_ValidationScriptsPartial")

    </div>
</div>

<script>
    function goBack() {
        if (document.referrer && document.referrer !== window.location.href) {
            window.history.back();
        } else {
            window.location.href = '/Inventory/Index';
        }
    }
</script>

<style>
    .form-label {
        font-size: 13px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
        display: block;
    }

    .form-input {
        width: 100%;
        padding: 10px 12px;
        border-radius: 6px;
        border: 1px solid #d1d5db;
        outline: none;
        font-size: 14px;
    }

    .form-input:focus {
        border-color: #2a5298;
        box-shadow: 0 0 0 2px rgba(42,82,152,0.15);
    }
</style>
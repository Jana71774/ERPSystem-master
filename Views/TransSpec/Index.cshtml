@model List<ERPSystem.Models.TransSpecDataModel>

@{
    var stockId = ViewBag.StockID;
    var itemcode = ViewBag.Itemcode;
}

<link rel="stylesheet" href="~/css/site.css" />
<link href="https://cdn.syncfusion.com/ej2/25.1.35/material.css" rel="stylesheet">

<div class="main-content">

    <!-- TOP BAR -->
    <div class="topbar" style="display:flex;justify-content:space-between;align-items:center">

        <div>
            <h3>📋 Variable Specifications</h3>
            <small style="color:#6b7280">
                Stock ID: <b>@stockId</b> | Item Code: <b>@itemcode</b>
            </small>
        </div>

        <div style="display:flex;gap:12px;align-items:center">

            <button type="button"
                    onclick="history.back();"
                    style="background:#e5e7eb;color:#111;
                           padding:8px 14px;border-radius:6px;
                           border:none;font-weight:600;">
                ← Back
            </button>

            <a asp-controller="TransSpec"
               asp-action="Create"
               asp-route-stockId="@stockId"
               asp-route-itemcode="@itemcode"
               style="background:#2563eb;color:white;
                      padding:8px 14px;border-radius:6px;
                      text-decoration:none;font-weight:600;">
                + Add Spec
            </a>

        </div>
    </div>

    <!-- CARD -->
    <div class="card" style="margin-top:20px;padding:20px">

        <div id="Grid"></div>

    </div>

</div>

<script src="https://cdn.syncfusion.com/ej2/25.1.35/dist/ej2.min.js"></script>

<script>
    var transSpecData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

    var grid = new ej.grids.Grid({
        dataSource: transSpecData,
        height: 450,

        allowPaging: true,
        allowSorting: true,
        allowFiltering: true,
        allowSearching: true,

        toolbar: ['Search'],

        columns: [
            { field: 'StockID', headerText: 'Stock ID', width: 120 },
            { field: 'ItemName', headerText: 'Item Name', width: 200 },
            { field: 'SpecName', headerText: 'Spec Name', width: 200 },
            { field: 'Value', headerText: 'Value', width: 150 },
            { field: 'Itemcode', headerText: 'Item Code', width: 150 },

            {
                headerText: 'Edit',
                width: 120,
                template: function (data) {
                    return `<a href="/TransSpec/Edit?stockId=${data.StockID}&specid=${data.SpecID}&itemcode=${data.Itemcode}"
                               style="color:#2563eb;font-weight:600;text-decoration:none">
                               ✏ Edit
                            </a>`;
                }
            }
        ]
    });

    grid.appendTo('#Grid');
</script>
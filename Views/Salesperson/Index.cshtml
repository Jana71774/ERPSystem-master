@model List<ERPSystem.Models.Salesperson>

<link rel="stylesheet" href="~/css/site.css" />

<!-- Syncfusion CSS -->
<link href="https://cdn.syncfusion.com/ej2/25.1.35/material.css" rel="stylesheet" />

<div class="main-content">

    <div class="topbar" style="display:flex;justify-content:space-between;align-items:center">
        <h3>Salespersons</h3>

        <div style="display:flex;gap:12px;align-items:center">

            <button type="button"
                    onclick="goBack();"
                    style="background:#e5e7eb;color:#111;
                           padding:8px 14px;border-radius:6px;
                           border:none;font-weight:600;">
                ← Back
            </button>

            <a asp-controller="Salesperson"
               asp-action="Create"
               style="background:#2a5298;color:white;
                      padding:8px 14px;border-radius:6px;
                      text-decoration:none;font-weight:600;">
                + Add Salesperson
            </a>

        </div>
    </div>

    <div class="card" style="margin-top:15px;padding:20px">

        <div id="Grid"></div>

    </div>

</div>

<!-- Syncfusion JS -->
<script src="https://cdn.syncfusion.com/ej2/25.1.35/dist/ej2.min.js"></script>

<script>
    var salesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

    var grid = new ej.grids.Grid({
        dataSource: salesData,
        height: 420,

        allowPaging: true,
        allowSorting: true,
        allowFiltering: true,
        allowSearching: true,

        toolbar: ['Search'],

        columns: [
            { field: 'EmpID', headerText: 'Emp ID', width: 120, textAlign: 'Center' },
            { field: 'Name', headerText: 'Name', width: 180 },
            { field: 'Region', headerText: 'Region', width: 160 },
            { field: 'Target', headerText: 'Target', width: 140, textAlign: 'Right' },

            {
                headerText: 'Action',
                width: 120,
                template: function (data) {
                    return `<a href="/Salesperson/Edit/${data.EmpID}"
                               style="color:#2563eb;font-weight:600;text-decoration:none;">
                               Edit
                            </a>`;
                }
            }
        ]
    });

    grid.appendTo('#Grid');


    function goBack() {
        if (document.referrer && document.referrer !== window.location.href) {
            window.history.back();
        } else {
            window.location.href = '/';
        }
    }
</script>
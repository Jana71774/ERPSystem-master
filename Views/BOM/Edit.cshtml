@model ERPSystem.Models.BOM
@{
    var product = ViewBag.Product as ERPSystem.Models.Product;
}

<div class="main-content">

    <!-- TOP BAR -->
    <div class="topbar" style="display:flex;justify-content:space-between;align-items:center">
        <div>
            <h3>✏ Edit BOM Item</h3>
            <span style="color:#6b7280">
                Product: @product?.ProdName (@product?.ModelNo)
            </span>
        </div>

        <!-- 🔙 BACK (PREVIOUS PAGE) -->
        <button type="button"
                onclick="history.back();"
                style="background:#e5e7eb;color:#111;padding:8px 14px;
                       border-radius:6px;border:none;font-weight:600;">
            ← Back
        </button>
    </div>

    <div class="card" style="max-width:950px;margin:auto;padding:30px">

        <form asp-action="Edit" method="post">

            <!-- KEYS -->
            <input type="hidden" name="BOMID" value="@Model.BOMID" />
            <input type="hidden" name="ProductID" value="@product?.ProductID" />
            <input type="hidden" name="ModelNo" value="@product?.ModelNo" />

            <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:22px">

                <div>
                    <label class="form-label">Item Code</label>
                    <input name="ItemCode" value="@Model.ItemCode" class="form-input" />
                </div>

                <div>
                    <label class="form-label">Item Name</label>
                    <input name="ItemName" value="@Model.ItemName" class="form-input" />
                </div>

                <div>
                    <label class="form-label">Quantity</label>
                    <input type="number" name="Qty" value="@Model.Qty" class="form-input" />
                </div>

                <div style="grid-column:1/3">
                    <label class="form-label">Description</label>
                    <textarea name="Description" class="form-input">@Model.Description</textarea>
                </div>

            </div>

            <div style="margin-top:30px;display:flex;justify-content:flex-end;gap:15px">

                <!-- 🔙 CANCEL = PREVIOUS PAGE -->
                <button type="button"
                        onclick="history.back();"
                        style="background:#e5e7eb;color:#111;padding:10px 18px;
                               border-radius:6px;border:none;font-weight:600;">
                    Cancel
                </button>

                <button type="submit"
                        style="background:#2563eb;color:white;padding:12px 24px;
                               border-radius:8px;border:none;font-weight:600;">
                    💾 Update Component
                </button>

            </div>

        </form>

    </div>
</div>

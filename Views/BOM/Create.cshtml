@model ERPSystem.Models.BOM

@{
    var product = ViewBag.Product as ERPSystem.Models.Product;
}

@using Microsoft.AspNetCore.Mvc.Rendering

<link rel="stylesheet" href="~/css/site.css" />

<div class="main-content">

    <div class="topbar" style="display:flex;justify-content:space-between;align-items:center">
        <div>
            <h3>➕ Add BOM Item</h3>
            <span style="color:#6b7280">
                Product: @product?.ProdName (@product?.ModelNo)
            </span>
        </div>

        <!-- BACK TO BOM INDEX -->
        <a asp-controller="BOM"
           asp-action="Index"
           asp-route-productId="@product?.ProductID"
           class="btn btn-outline-secondary px-4">
            ← Back
        </a>
    </div>

    <div class="card" style="max-width:950px;margin:auto;padding:30px">

        <form asp-action="Create" method="post">

            <!-- Hidden keys (important for POST) -->
            <input type="hidden" asp-for="ProductID" value="@product?.ProductID" />
            <input type="hidden" asp-for="ModelNo" value="@product?.ModelNo" />

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <!-- Section Header -->
            <div style="background:#f1f5f9;padding:15px;border-radius:8px;margin-bottom:25px">
                <h4 style="margin:0;color:#2563eb">Component Details</h4>
                <small style="color:#6b7280">Add item to BOM</small>
            </div>

            <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:22px">

                <!-- Product ID (readonly display) -->
                <div>
                    <label asp-for="ProductID" class="form-label"></label>
                    <input asp-for="ProductID"
                           class="form-input"
                           value="@product?.ProductID"
                           readonly
                           style="background:#e5e7eb;font-weight:600" />
                    <span asp-validation-for="ProductID" class="text-danger"></span>
                </div>

                <!-- Model No (readonly display) -->
                <div>
                    <label asp-for="ModelNo" class="form-label"></label>
                    <input asp-for="ModelNo"
                           class="form-input"
                           value="@product?.ModelNo"
                           readonly
                           style="background:#e5e7eb;font-weight:600" />
                    <span asp-validation-for="ModelNo" class="text-danger"></span>
                </div>

                <!-- Item Code Dropdown -->
                <div>
                    <label asp-for="ItemCode" class="form-label"></label>

                    <select asp-for="ItemCode"
                            class="form-input"
                            asp-items="@(ViewBag.Items as List<SelectListItem>)"
                            onchange="updateItemName(this)"
                            required>
                        <option value="">Select Item...</option>
                    </select>

                    <span asp-validation-for="ItemCode" class="text-danger"></span>
                </div>

                <!-- Item Name -->
                <div>
                    <label asp-for="ItemName" class="form-label"></label>
                    <input asp-for="ItemName" class="form-input" readonly />
                    <span asp-validation-for="ItemName" class="text-danger"></span>
                </div>

                <!-- Quantity -->
                <div>
                    <label asp-for="Qty" class="form-label"></label>
                    <input asp-for="Qty"
                           type="number"
                           step="0.01"
                           min="0"
                           class="form-input"
                           placeholder="Enter quantity" />
                    <span asp-validation-for="Qty" class="text-danger"></span>
                </div>

                <!-- Description -->
                <div style="grid-column:1/3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description"
                              rows="3"
                              class="form-input"
                              placeholder="Optional notes"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

            </div>

            <!-- Buttons -->
            <div style="margin-top:30px;display:flex;justify-content:flex-end;gap:15px">

                <!-- Cancel -->
                <a asp-controller="BOM"
                   asp-action="Index"
                   asp-route-productId="@product?.ProductID"
                   style="background:#e5e7eb;color:#111;padding:10px 18px;
                          border-radius:6px;border:none;font-weight:600;
                          text-decoration:none;display:inline-block;">
                    Cancel
                </a>

                <!-- Submit -->
                <button type="submit"
                        style="background:#2563eb;color:white;padding:12px 24px;
                               border-radius:8px;border:none;font-weight:600;cursor:pointer;">
                    ➕ Add Component
                </button>

            </div>

        </form>

        @await Html.PartialAsync("_ValidationScriptsPartial")

    </div>
</div>

<script>
    function updateItemName(select) {
        const selectedOption = select.options[select.selectedIndex];

        if (selectedOption.value) {
            // Expecting format: CODE - NAME
            const parts = selectedOption.text.split(' - ');

            if (parts.length > 1) {
                document.querySelector('input[name="ItemName"]').value = parts[1];
            } else {
                document.querySelector('input[name="ItemName"]').value = selectedOption.text;
            }
        } else {
            document.querySelector('input[name="ItemName"]').value = '';
        }
    }
</script>

<style>
    .form-label {
        font-size: 13px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
        display: block;
    }

    .form-input {
        width: 100%;
        padding: 10px 12px;
        border-radius: 6px;
        border: 1px solid #d1d5db;
        outline: none;
        font-size: 14px;
    }

    .form-input:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 2px rgba(37,99,235,0.15);
    }
</s
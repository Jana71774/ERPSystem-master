@model List<ERPSystem.Models.BOM>
@{
    var product = ViewBag.Product as ERPSystem.Models.Product;
}

<link href="https://cdn.syncfusion.com/ej2/25.1.35/material.css" rel="stylesheet" />

<div class="container-fluid mt-4">

    <!-- HEADER CARD (UNCHANGED) -->
    <div class="bg-white rounded-4 shadow-sm p-4 mb-4">

        <div class="d-flex justify-content-between align-items-center">

            <div>
                <h3 class="fw-bold mb-3">BOM</h3>

                <div class="d-flex gap-3">

                    <div class="px-3 py-2 bg-light rounded-3">
                        <small class="text-muted">Product ID</small><br />
                        <strong>@product?.ProductID</strong>
                    </div>

                    <div class="px-3 py-2 bg-light rounded-3">
                        <small class="text-muted">Product Name</small><br />
                        <strong>@product?.ProdName</strong>
                    </div>

                    <div class="px-3 py-2 bg-primary bg-opacity-10 rounded-3">
                        <small class="text-muted">Model No</small><br />
                        <strong class="text-primary">@product?.ModelNo</strong>
                    </div>

                </div>
            </div>

            <div class="d-flex gap-2">

                <a asp-controller="Product" asp-action="Index" class="btn btn-outline-secondary px-4">
                    ← Products
                </a>

                <a asp-controller="BOM"
                   asp-action="Create"
                   asp-route-productId="@product?.ProductID"
                   class="btn btn-primary px-4">
                    Add BOM
                </a>

                <a asp-controller="ItemData"
                   asp-action="SelectForBOM"
                   asp-route-productId="@product?.ProductID"
                   asp-route-modelNo="@product?.ModelNo"
                   class="btn btn-primary px-4">
                    Add Item
                </a>

            </div>

        </div>
    </div>

    <!-- GRID CARD -->
    <div class="bg-white rounded-4 shadow-sm p-4">

        <div id="Grid"></div>

    </div>

</div>

<script src="https://cdn.syncfusion.com/ej2/25.1.35/dist/ej2.min.js"></script>

<script>
    var bomData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

    var grid = new ej.grids.Grid({
        dataSource: bomData,
        height: 450,

        allowPaging: true,
        allowSorting: true,
        allowFiltering: true,
        allowSearching: true,

        toolbar: ['Search'],

        columns: [
            { field: 'ModelNo', headerText: 'Model No', width: 150 },
            { field: 'Description', headerText: 'Description', width: 220 },
            { field: 'ItemCode', headerText: 'Item Code', width: 150 },
            { field: 'ItemName', headerText: 'Item Name', width: 200 },

            {
                headerText: 'Qty',
                width: 120,
                textAlign: 'Center',
                template: function (data) {
                    return `<span style="background:#facc15;color:#111;
                                         padding:6px 14px;border-radius:20px;
                                         font-weight:600;">
                                ${data.Qty}
                            </span>`;
                }
            },

            {
                headerText: 'Edit',
                width: 120,
                template: function (data) {
                    return `<a href="/BOM/Edit/${data.BOMID}?productId=${data.ProductID}"
                               style="color:#2563eb;font-weight:600;text-decoration:none">
                               Edit
                            </a>`;
                }
            }
        ]
    });

    grid.appendTo('#Grid');
</script>
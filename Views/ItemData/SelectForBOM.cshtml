@model IEnumerable<ERPSystem.Models.ItemData>
@{
    ViewData["Title"] = "Item Data";
    Layout = "_Layout";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    .page-box {
        border: 2px solid #2da2ff;
        border-radius: 6px;
        background: #f9fbfd;
        padding: 20px;
    }

    .page-title {
        font-weight: 600;
        font-size: 16px;
    }
</style>

<div class="container-fluid mt-3">
    <div class="page-box">

        <!-- HEADER -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="page-title">Item Data</div>

            <div class="d-flex gap-2">
                <!-- 🔙 BACK (PREVIOUS PAGE) -->
                <button type="button"
                        class="btn btn-sm btn-secondary"
                        onclick="history.back();">
                    ← Back
                </button>

                <!-- ➕ CREATE -->
                <a asp-controller="ItemData"
                   asp-action="Create"
                   class="btn btn-sm btn-primary">
                    + Add Item
                </a>
            </div>
        </div>

        <!-- ITEM TABLE -->
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th style="width:25%">Item Code</th>
                    <th style="width:45%">Item Name</th>
                    <th style="width:30%" class="text-end">Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.itemcode</td>
                        <td>@item.itemname</td>

                        <td class="text-end">

                            <!-- EDIT -->
                            <a asp-controller="ItemData"
                               asp-action="Edit"
                               asp-route-id="@item.itemcode"
                               class="btn btn-sm btn-outline-primary">
                                Edit
                            </a>

                            <!-- SPEC -->
                            <a asp-controller="Spec"
                               asp-action="Index"
                               asp-route-itemCode="@item.itemcode"
                               asp-route-itemName="@item.itemname"
                               class="btn btn-sm btn-outline-secondary ms-1">
                                Spec
                            </a>

                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>

@model IEnumerable<ERPSystem.Models.ItemData>
@{
    ViewData["Title"] = "Item Data";
    Layout = "_Layout";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.syncfusion.com/ej2/25.1.35/material.css" rel="stylesheet">

<style>
    .page-box {
        border: 2px solid #2da2ff;
        border-radius: 6px;
        background: #f9fbfd;
        padding: 20px;
    }

    .page-title {
        font-weight: 600;
        font-size: 16px;
    }
</style>

<div class="container-fluid mt-3">
    <div class="page-box">

        <!-- HEADER -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="page-title">Item Data</div>

            <div class="d-flex gap-2">
                <a asp-controller="BOM"
                   asp-action="Index"
                   asp-route-productId="@ViewBag.Product?.ProductID"
                   class="btn btn-outline-secondary px-4">
                    ← back
                </a>

                <a asp-controller="ItemData"
                   asp-action="Create"
                   class="btn btn-sm btn-primary">
                    + Add Item
                </a>
            </div>
        </div>

        <!-- GRID -->
        <div id="Grid"></div>

    </div>
</div>

<script src="https://cdn.syncfusion.com/ej2/25.1.35/dist/ej2.min.js"></script>

<script>
    var itemData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

    var grid = new ej.grids.Grid({
        dataSource: itemData,
        height: 450,

        allowPaging: true,
        allowSorting: true,
        allowFiltering: true,
        allowSearching: true,

        toolbar: ['Search'],

        columns: [
            { field: 'ItemCode', headerText: 'Item Code', width: 160 },
            { field: 'ItemName', headerText: 'Item Name', width: 220 },
            { field: 'ItemDataValue', headerText: 'Item Data', width: 220 },

            {
                headerText: 'Edit',
                width: 120,
                template: function (data) {
                    return `<a href="/ItemData/Edit/${data.ItemCode}"
                               style="color:#2563eb;font-weight:600;text-decoration:none">
                               Edit
                            </a>`;
                }
            },

            {
                headerText: 'Spec',
                width: 120,
                template: function (data) {
                    return `<a href="/Spec/Index?itemCode=${data.ItemCode}&itemName=${data.ItemName}"
                               style="color:#6b7280;font-weight:600;text-decoration:none">
                               Spec
                            </a>`;
                }
            }
        ]
    });

    grid.appendTo('#Grid');
</script>
@model List<ERPSystem.Models.PO>
<link rel="stylesheet" href="~/css/site.css" />

<!-- Syncfusion CSS -->
<link href="https://cdn.syncfusion.com/ej2/25.1.35/material.css" rel="stylesheet" />

<div class="main-content">

    <!-- Top Bar -->
    <div class="topbar"
         style="display:flex;justify-content:space-between;align-items:center">

        <div style="display:flex;align-items:center;gap:20px">
            <div>
                <h3 style="margin:0">📦 Purchase Orders</h3>
                <small style="color:#666">Manage all purchase orders</small>
            </div>

            <a asp-controller="Customer"
               asp-action="Index"
               style="background:#e0ecff;color:#1e40af;
                      padding:6px 14px;border-radius:6px;
                      text-decoration:none;font-weight:600;">
                Customer
            </a>

            <a asp-controller="Salesperson"
               asp-action="Index"
               style="background:#dcfce7;color:#166534;
                      padding:6px 14px;border-radius:6px;
                      text-decoration:none;font-weight:600;">
                Salesperson
            </a>
        </div>

        <div style="display:flex;gap:12px;align-items:center">

            <a asp-controller="Dashboard"
               asp-action="Index"
               style="background:#e5e7eb;color:#111;
                      padding:8px 14px;border-radius:6px;
                      font-weight:600;text-decoration:none;">
                ← Back
            </a>

            <a asp-controller="PO" asp-action="Create"
               style="background:#2a5298;color:white;
                      padding:10px 18px;border-radius:8px;
                      text-decoration:none;font-weight:600;">
                ➕ Create PO
            </a>

        </div>
    </div>

    <!-- GRID -->
    <div class="card" style="margin-top:20px;padding:20px">

        <div id="Grid"></div>

    </div>

</div>

<!-- Syncfusion JS -->
<script src="https://cdn.syncfusion.com/ej2/25.1.35/dist/ej2.min.js"></script>

<script>
    var poData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

    var grid = new ej.grids.Grid({
        dataSource: poData,
        height: 480,

        allowPaging: true,
        allowSorting: true,
        allowFiltering: true,
        allowSearching: true,

        toolbar: ['Search'],

        columns: [
            {
                field: 'OrderID',
                headerText: 'Order ID',
                width: 100,
                template: function (data) {
                    return `<span style="background:#e0ecff;color:#2a5298;
                                         padding:4px 10px;border-radius:20px;
                                         font-weight:600;font-size:12px">
                                ${data.OrderID}
                            </span>`;
                }
            },

            { field: 'PONo', headerText: 'PO No', width: 100 },

            { field: 'Customerid', headerText: 'Customer', width: 100 },

            { field: 'productid', headerText: 'Product', width: 100 },

            {
                field: 'qty',
                headerText: 'Qty',
                width: 80,
                template: function (data) {
                    return `<span style="background:#fef3c7;color:#92400e;
                                         padding:4px 10px;border-radius:20px;
                                         font-weight:600;font-size:12px">
                                ${data.qty}
                            </span>`;
                }
            },

            { field: 'Salesperson', headerText: 'Salesperson', width: 120 },

            {
                field: 'WarrantyYEAR',
                headerText: 'Warranty',
                width: 140,
                template: function (data) {
                    return `${data.WarrantyYEAR} Year`;
                }
            },

            {
                headerText: 'Attachment',
                width: 140,
                template: function (data) {
                    if (data.Attachment && data.Attachment !== "") {
                        return `<a href="${data.Attachment}" target="_blank"
                                   style="color:#2a5298;font-weight:600;text-decoration:none">
                                   📎 View
                                </a>`;
                    }
                    return `<span style="color:#999">No File</span>`;
                }
            },

            {
                headerText: 'Action',
                width: 120,
                template: function (data) {
                    return `<a href="/PO/Edit/${data.OrderID}"
                               style="background:#e0ecff;color:#2a5298;
                                      padding:6px 12px;border-radius:6px;
                                      text-decoration:none;font-weight:600">
                               ✏ Edit
                            </a>`;
                }
            }
        ]
    });

    grid.appendTo('#Grid');
</script>
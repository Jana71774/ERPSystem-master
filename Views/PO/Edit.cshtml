@model ERPSystem.Models.PO
<link rel="stylesheet" href="~/css/site.css" />

<div class="main-content">

    <div class="topbar" style="display:flex;justify-content:space-between;align-items:center">
        <h3>✏ Edit Purchase Order</h3>
        <a asp-controller="PO" asp-action="Index"
           style="text-decoration:none;color:#2a5298;font-weight:600;">
            ← Back to PO List
        </a>
    </div>

    <div class="card" style="max-width:1100px;margin:auto;padding:30px">

        <form asp-action="Edit" method="post" enctype="multipart/form-data">

            <!-- Hidden Primary Key -->
            <input type="hidden" asp-for="OrderID" />

            <!-- Header -->
            <div style="background:#f1f5f9;padding:15px;border-radius:8px;margin-bottom:25px;
                        display:flex;justify-content:space-between;align-items:center">

                <div>
                    <h4 style="margin:0;color:#2a5298">Purchase Order Details</h4>
                    <small style="color:#666">Update purchase order</small>
                </div>

                <div>
                    <label style="font-size:12px;color:#666">Order ID (System)</label>
                    <input value="@Model.OrderID" readonly
                           style="background:#e5e7eb;font-weight:bold;text-align:center;width:160px" />
                </div>
            </div>

            <!-- Form Grid -->
            <!-- FIELD ORDER NOW MATCHES CREATE FORM -->
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px">

                <!-- PO No -->
                <div>
                    <label asp-for="PONo" class="form-label">PO No</label>
                    <input asp-for="PONo" class="form-input" />
                    <span asp-validation-for="PONo" class="text-danger"></span>
                </div>

                <!-- Customer ID -->
                <div>
                    <label asp-for="Customerid" class="form-label">Customer ID</label>
                    <input asp-for="Customerid" class="form-input" />
                    <span asp-validation-for="Customerid" class="text-danger"></span>
                </div>

                <!-- Quantity -->
                <div>
                    <label asp-for="qty" class="form-label">Quantity</label>
                    <input asp-for="qty" type="number" class="form-input" />
                    <span asp-validation-for="qty" class="text-danger"></span>
                </div>

                <!-- Product ID -->
                <div>
                    <label asp-for="productid" class="form-label">Product ID</label>
                    <input asp-for="productid" class="form-input" />
                    <span asp-validation-for="productid" class="text-danger"></span>
                </div>

                <!-- Licence Type -->
                <div>
                    <label asp-for="LicenceType" class="form-label">Licence Type</label>
                    <input asp-for="LicenceType" class="form-input" />
                    <span asp-validation-for="LicenceType" class="text-danger"></span>
                </div>

                <!-- Sale Type -->
                <div>
                    <label asp-for="Saletype" class="form-label">Sale Type</label>
                    <input asp-for="Saletype" class="form-input" />
                    <span asp-validation-for="Saletype" class="text-danger"></span>
                </div>

                <!-- Salesperson -->
                <div>
                    <label asp-for="Salesperson" class="form-label">Salesperson</label>
                    <input asp-for="Salesperson" class="form-input" />
                    <span asp-validation-for="Salesperson" class="text-danger"></span>
                </div>

                <!-- Warranty Year -->
                <div>
                    <label asp-for="WarrantyYEAR" class="form-label">Warranty (YEAR)</label>
                    <input asp-for="WarrantyYEAR" type="number" class="form-input" />
                    <span asp-validation-for="WarrantyYEAR" class="text-danger"></span>
                </div>

                <!-- Attachment -->
                <div>
                    <label class="form-label">Attachment</label>
                    <input type="file" name="AttachmentFile" accept=".pdf" class="form-input" />

                    @if (!string.IsNullOrEmpty(Model.Attachment))
                    {
                        <small>
                            Current:
                            <a href="@Model.Attachment" target="_blank">View File</a>
                        </small>
                    }
                </div>

                <!-- Description -->
                <div style="grid-column:1/4">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-input" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

            </div>

            <!-- Validation Summary -->
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <!-- Buttons -->
            <div style="margin-top:30px;display:flex;justify-content:flex-end;gap:15px">

                <a asp-controller="PO" asp-action="Index"
                   style="background:#e5e7eb;color:#111;padding:10px 18px;border-radius:6px;
                          text-decoration:none;font-weight:600;">
                    Cancel
                </a>

                <button type="submit"
                        style="background:#2a5298;color:white;padding:12px 24px;border-radius:8px;
                               border:none;font-weight:600;cursor:pointer;">
                    💾 Update PO
                </button>

            </div>

        </form>

        @await Html.PartialAsync("_ValidationScriptsPartial")

    </div>
</div>

<style>
    .form-label {
        font-size: 13px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
        display: block;
    }

    .form-input {
        width: 100%;
        padding: 10px 12px;
        border-radius: 6px;
        border: 1px solid #d1d5db;
        outline: none;
        font-size: 14px;
    }

    .form-input:focus {
        border-color: #2a5298;
        box-shadow: 0 0 0 2px rgba(42,82,152,0.15);
    }
</style>
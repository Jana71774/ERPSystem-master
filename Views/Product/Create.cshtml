@model ERPSystem.Models.Product
<link rel="stylesheet" href="~/css/site.css" />

<div class="main-content">

    <div class="topbar" style="display:flex;justify-content:space-between;align-items:center">
        <h3>➕ Create Product</h3>

        <!-- BACK BUTTON -->
        <button type="button"
                onclick="goBack();"
                style="background:none;border:none;
                       color:#2563eb;font-weight:600;
                       cursor:pointer;">
            ← Back
        </button>
    </div>

    <div class="card" style="max-width:950px;margin:auto;padding:30px">

        <form asp-action="Create" method="post">

            <!-- FORM GRID -->
            <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:22px">

                <!-- Product ID -->
                <div>
                    <label asp-for="ProductID" class="form-label">Product ID</label>
                    <input asp-for="ProductID" class="form-input" />
                    <span asp-validation-for="ProductID" class="text-danger"></span>
                </div>

                <!-- Product Name -->
                <div>
                    <label asp-for="ProdName" class="form-label">Product Name</label>
                    <input asp-for="ProdName" class="form-input" />
                    <span asp-validation-for="ProdName" class="text-danger"></span>
                </div>

                <!-- Model No -->
                <div>
                    <label asp-for="ModelNo" class="form-label">Model No</label>
                    <input asp-for="ModelNo" class="form-input" />
                    <span asp-validation-for="ModelNo" class="text-danger"></span>
                </div>

                <!-- Model Name -->
                <div>
                    <label asp-for="ModelName" class="form-label">Model Name</label>
                    <input asp-for="ModelName" class="form-input" />
                    <span asp-validation-for="ModelName" class="text-danger"></span>
                </div>

                <!-- Description -->
                <div style="grid-column:1/3">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-input" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

            </div>

            <!-- VALIDATION SUMMARY -->
            <div asp-validation-summary="All" class="text-danger" style="margin-top:15px"></div>

            <!-- BUTTONS -->
            <div style="margin-top:25px;display:flex;justify-content:flex-end;gap:12px">

                <button type="button"
                        onclick="goBack();"
                        style="background:#e5e7eb;color:#111;
                               padding:10px 18px;border-radius:6px;
                               border:none;font-weight:600;cursor:pointer;">
                    Cancel
                </button>

                <button type="submit"
                        style="background:#2a5298;color:white;
                               padding:12px 24px;border-radius:8px;
                               border:none;font-weight:600;cursor:pointer;">
                    💾 Save Product
                </button>

            </div>

        </form>

        @await Html.PartialAsync("_ValidationScriptsPartial")

    </div>
</div>

<script>
    function goBack() {
        if (document.referrer && document.referrer !== window.location.href) {
            window.history.back();
        } else {
            window.location.href = '/Product/Index';
        }
    }
</script>

<style>
    .form-label {
        font-size: 13px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
        display: block;
    }

    .form-input {
        width: 100%;
        padding: 10px 12px;
        border-radius: 6px;
        border: 1px solid #d1d5db;
        outline: none;
        font-size: 14px;
    }

    .form-input:focus {
        border-color: #2a5298;
        box-shadow: 0 0 0 2px rgba(42,82,152,0.15);
    }
</style>
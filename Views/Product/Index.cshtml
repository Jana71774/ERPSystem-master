@model IEnumerable<ERPSystem.Models.Product>

@{
    ViewData["Title"] = "Product Management";
}

<div class="container-fluid">

    <div class="card shadow">
        <div class="card-header bg-success text-white">
            <h4>Product Management</h4>
        </div>

        <div class="card-body">

            <ejs-grid id="ProductGrid"
                      dataSource="@Model"
                      allowPaging="true"
                      allowSorting="true"
                      allowFiltering="true"
                      toolbar="@(new List<string>() { "Add", "Edit", "Delete", "Search", "ExcelExport" })">

                <e-data-manager url="/Product/UrlDataSource"
                                insertUrl="/Product/Insert"
                                updateUrl="/Product/Update"
                                removeUrl="/Product/Delete"
                                adaptor="UrlAdaptor">
                </e-data-manager>

                <e-grid-editSettings allowAdding="true"
                                     allowEditing="true"
                                     allowDeleting="true"
                                     mode="Dialog">
                </e-grid-editSettings>

                <e-grid-columns>

                    <e-grid-column field="ProductID"
                                   headerText="Product ID"
                                   isPrimaryKey="true"
                                   validationRules="@(new { required = true })"
                                   width="150">
                    </e-grid-column>

                    <e-grid-column field="ProdName"
                                   headerText="Product Name"
                                   width="200">
                    </e-grid-column>

                    <e-grid-column field="ModelNo"
                                   headerText="Model No"
                                   width="150">
                    </e-grid-column>

                    <e-grid-column field="ModelName"
                                   headerText="Model Name"
                                   width="200">
                    </e-grid-column>

                    <e-grid-column field="Description"
                                   headerText="Description"
                                   width="250">
                    </e-grid-column>

                </e-grid-columns>

            </ejs-grid>

        </div>
    </div>

</div>
@model List<ERPSystem.Models.Product>
<link rel="stylesheet" href="~/css/site.css" />

<!-- Syncfusion CSS -->
<link href="https://cdn.syncfusion.com/ej2/25.1.35/material.css" rel="stylesheet" />

<div class="main-content">

    <!-- Header -->
    <div class="topbar" style="display:flex;justify-content:space-between;align-items:center">
        <h3>Products</h3>

        <div style="display:flex;gap:15px;align-items:center">

            <a asp-controller="Dashboard" asp-action="Index"
               style="background:#e5e7eb;color:#111;
                      padding:6px 14px;border-radius:6px;
                      border:none;font-weight:600;text-decoration:none;">
                ← Home
            </a>

            <a asp-controller="Product" asp-action="Create"
               style="color:#2563eb;font-weight:600;text-decoration:none;">
                + Add Product
            </a>

        </div>
    </div>

    <!-- GRID -->
    <div class="card" style="margin-top:20px;padding:20px">

        <div id="Grid"></div>

    </div>

</div>

<!-- Syncfusion JS -->
<script src="https://cdn.syncfusion.com/ej2/25.1.35/dist/ej2.min.js"></script>

<script>
    var productData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

    var grid = new ej.grids.Grid({
        dataSource: productData,
        height: 450,

        allowPaging: true,
        allowSorting: true,
        allowFiltering: true,
        allowSearching: true,

        toolbar: ['Search'],

        columns: [
            { field: 'ProductID', headerText: 'Product ID', width: 130 },
            { field: 'ProdName', headerText: 'Product Name', width: 200 },
            { field: 'ModelNo', headerText: 'Model No', width: 150 },
            { field: 'Description', headerText: 'Description', width: 250 },

            {
                headerText: 'Edit',
                width: 120,
                template: function (data) {
                    return `<a href="/Product/Edit/${data.ProductID}"
                               style="background:#e0ecff;color:#2a5298;
                                      padding:6px 12px;border-radius:6px;
                                      text-decoration:none;font-weight:600">
                               Edit
                            </a>`;
                }
            },

            {
                headerText: 'BOM',
                width: 120,
                template: function (data) {
                    return `<a href="/BOM/Index?productId=${data.ProductID}"
                               style="color:#10b981;font-weight:600;text-decoration:none">
                               BOM
                            </a>`;
                }
            }
        ]
    });

    grid.appendTo('#Grid');
</script>
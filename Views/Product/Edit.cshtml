@model ERPSystem.Models.Product
<link rel="stylesheet" href="~/css/site.css" />

<div class="main-content">

    <div class="topbar" style="display:flex;justify-content:space-between;align-items:center">
        <h3>✏ Edit Product</h3>

        <!-- 🔙 BACK (PREVIOUS PAGE) -->
        <button type="button"
                onclick="goBack();"
                style="background:none;border:none;
                       color:#2563eb;font-weight:600;
                       cursor:pointer;">
            ← Back
        </button>
    </div>

    <div class="card" style="max-width:950px;margin:auto;padding:30px">

        <form asp-action="Edit" method="post">

            <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:22px">

                <div>
                    <label>Product ID</label>
                    <input name="ProductID" value="@Model.ProductID" readonly />
                </div>

                <div>
                    <label>Product Name</label>
                    <input name="ProdName" value="@Model.ProdName" />
                </div>

                <div>
                    <label>Model No</label>
                    <input name="ModelNo" value="@Model.ModelNo" />
                </div>

                <div>
                    <label>Model Name</label>
                    <input name="ModelName" value="@Model.ModelName" />
                </div>

                <div style="grid-column:1/3">
                    <label>Description</label>
                    <textarea name="Description">@Model.Description</textarea>
                </div>

            </div>

            <div style="margin-top:25px;text-align:right">
                <button type="submit">Update Product</button>
            </div>

        </form>

    </div>
</div>

<script>
    function goBack() {
        if (document.referrer && document.referrer !== window.location.href) {
            window.history.back();
        } else {
            // fallback (safe default)
            window.location.href = '/Product/Index';
        }
    }
</script>
